###  http://example.org/ontology#Author
<http://example.org/ontology#Author> rdf:type owl:Class ;
                                     rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                       owl:onProperty <http://example.org/ontology#hasName> ;
                                                       owl:cardinality "1"^^xsd:nonNegativeInteger
                                                     ] .


###  http://example.org/ontology#AuthorDBLP
<http://example.org/ontology#AuthorDBLP> rdf:type owl:Class ;
                                         rdfs:subClassOf <http://example.org/ontology#Author> ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <http://example.org/ontology#hasPID> ;
                                                           owl:someValuesFrom xsd:string
                                                         ] ;
                                         owl:disjointWith <http://example.org/ontology#AuthorIEEE> .


###  http://example.org/ontology#AuthorIEEE
<http://example.org/ontology#AuthorIEEE> rdf:type owl:Class ;
                                         rdfs:subClassOf <http://example.org/ontology#Author> .


###  http://example.org/ontology#Authorship
<http://example.org/ontology#Authorship> rdf:type owl:Class .


###  http://example.org/ontology#Publication
<http://example.org/ontology#Publication> rdf:type owl:Class ;
                                          rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                            owl:onProperty <http://example.org/ontology#hasAuthor> ;
                                                            owl:minCardinality "1"^^xsd:nonNegativeInteger
                                                          ] ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <http://example.org/ontology#hasTitle> ;
                                                            owl:cardinality "1"^^xsd:nonNegativeInteger
                                                          ] ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <http://example.org/ontology#hasYear> ;
                                                            owl:cardinality "1"^^xsd:nonNegativeInteger
                                                          ] .


###  http://example.org/ontology#PublicationDBLP
<http://example.org/ontology#PublicationDBLP> rdf:type owl:Class ;
                                              rdfs:subClassOf <http://example.org/ontology#Publication> ;
                                              owl:disjointWith <http://example.org/ontology#PublicationIEEE> .


###  http://example.org/ontology#PublicationIEEE
<http://example.org/ontology#PublicationIEEE> rdf:type owl:Class ;
                                              rdfs:subClassOf <http://example.org/ontology#Publication> ,
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <http://example.org/ontology#hasDOI> ;
                                                                owl:someValuesFrom xsd:string
                                                              ] .


